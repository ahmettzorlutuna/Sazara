# Sazara MVP — local development env
# Copy to `.env` and adjust. Real `.env` is git-ignored.

# Database credentials (only used inside Docker network)
DB_PASSWORD=sazara_local_dev
DB_ROOT_PASSWORD=root_local_dev

# Optional: WP admin bootstrap (used by `make bootstrap`)
WP_ADMIN_USER=ahmet
WP_ADMIN_PASSWORD=local-only-change-me
WP_ADMIN_EMAIL=ahmet@sazara.com.tr
WP_SITE_TITLE=Sazara Teknoloji
WP_SITE_URL=http://localhost:8080
